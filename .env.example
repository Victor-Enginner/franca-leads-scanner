# Google Cloud Console > APIs & Services > Credentials
# Ative a "Places API" (legacy) no projeto antes de gerar a key.
GOOGLE_PLACES_API_KEY=

# Supabase > Project Settings > API
SUPABASE_URL=
# Use a service_role key (não a anon) — as rotas de API rodam só no servidor,
# nunca expostas ao navegador.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Modo multiusuário (opcional — sem estas 2, o app roda single-user) ----
# Mesmo valor de SUPABASE_URL:
NEXT_PUBLIC_SUPABASE_URL=
# A chave PUBLISHABLE/anon (sb_publishable_...) — essa é pública por design:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Senha administrativa sua, pra liberar plano de quem comprou
# (POST /api/admin/liberar com header x-admin-token):
ADMIN_TOKEN=
